# --- GLM Coding Plan ---
# Required for GLM data. The raw key (sent as Authorization header, no "Bearer " prefix).
GLM_API_KEY=
# Optional: switch to international endpoint (api.z.ai) if you use z.ai instead of bigmodel.cn
# GLM_BASE_URL=https://api.z.ai

# --- Codex (ChatGPT) ---
# Path to Codex/ChatGPT auth file. Defaults to ~/.codex/auth.json
# CODEX_AUTH_PATH=/Users/you/.codex/auth.json
# Override the usage endpoint (internal, may change)
# CODEX_USAGE_URL=https://chatgpt.com/backend-api/wham/usage

# --- Claude Code ---
# Reads OAuth token from ~/.claude/.credentials.json (created when you log in
# via `claude` with a subscription). No key needed — just be logged in.
# Override the credentials path or usage API if your setup differs:
# CLAUDE_CREDENTIALS_PATH=/Users/you/.claude/.credentials.json
# CLAUDE_USAGE_API=https://api.anthropic.com/api/oauth/usage
# Fetch timeout (ms)
# CLAUDE_TIMEOUT_MS=15000

# --- Server ---
# Port is fixed at 5928 in package.json scripts (next start/dev -p 5928).
# Next.js binds the port before loading .env, so PORT here would be ignored.

# --- SuperGrok (xAI Grok / grok.com) ---
# Path to the Grok CLI credentials (created by running `grok login`).
# The dashboard reads the OAuth token and calls the same billing endpoint
# the CLI uses (weekly usage pool for SuperGrok / unified billing).
# GROK_AUTH_PATH=/Users/you/.grok/auth.json
# Override endpoints only if you are using a proxy / custom build:
# GROK_BILLING_URL=https://cli-chat-proxy.grok.com/v1/billing?format=credits
# GROK_SETTINGS_URL=https://cli-chat-proxy.grok.com/v1/settings

# --- MiniMax (国内端点默认 minimaxi.com) ---
# 使用 Token Plan 的 Subscription Key（不是普通的 pay-as-you-go Key）
# 国内默认使用 https://www.minimaxi.com/v1/token_plan/remains
# 如果是国际版可设置 MINIMAX_BASE_URL=https://www.minimax.io
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://www.minimaxi.com

# --- Kimi (Kimi Code 会员) ---
# Reads OAuth credentials from ~/.kimi-code/credentials/kimi-code.json (written
# by the Kimi Code CLI login). Expired tokens are refreshed automatically and
# written back. Nothing to set if you use the CLI on this machine.
# KIMI_CREDENTIALS_PATH=/Users/you/.kimi-code/credentials/kimi-code.json
# Or skip OAuth entirely with an API Key from the Kimi Code Console:
# KIMI_API_KEY=
# Override endpoints only if you are using a proxy / custom build:
# KIMI_USAGE_URL=https://api.kimi.com/coding/v1/usages
# KIMI_TOKEN_URL=https://auth.kimi.com/api/oauth/token

# --- Volcengine (火山方舟 Coding Plan) ---
# AK/SK pair from 火山引擎控制台 → 密钥管理 (https://console.volcengine.com/iam/keymanage/)
# Used to sign GetAFPUsage requests (HMAC-SHA256 V4). Required for the Volcengine card.
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=
