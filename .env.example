# --- GLM Coding Plan ---
# Required for GLM data. The raw key (sent as Authorization header, no "Bearer " prefix).
GLM_API_KEY=
# Optional: switch to international endpoint (api.z.ai) if you use z.ai instead of bigmodel.cn
# GLM_BASE_URL=https://api.z.ai

# --- Codex (ChatGPT) ---
# Path to Codex/ChatGPT auth file. Defaults to ~/.codex/auth.json
# CODEX_AUTH_PATH=/Users/you/.codex/auth.json
# Override the usage endpoint (internal, may change)
# CODEX_USAGE_URL=https://chatgpt.com/backend-api/wham/usage

# --- Claude Code ---
# Reads OAuth token from ~/.claude/.credentials.json (created when you log in
# via `claude` with a subscription). No key needed — just be logged in.
# Override the credentials path or usage API if your setup differs:
# CLAUDE_CREDENTIALS_PATH=/Users/you/.claude/.credentials.json
# CLAUDE_USAGE_API=https://api.anthropic.com/api/oauth/usage
# Fetch timeout (ms)
# CLAUDE_TIMEOUT_MS=15000

# --- Server ---
# Port is fixed at 5928 in package.json scripts (next start/dev -p 5928).
# Next.js binds the port before loading .env, so PORT here would be ignored.

# --- Volcengine (火山方舟 Coding Plan) ---
# AK/SK pair from 火山引擎控制台 → 密钥管理 (https://console.volcengine.com/iam/keymanage/)
# Used to sign GetAFPUsage requests (HMAC-SHA256 V4). Required for the Volcengine card.
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=
